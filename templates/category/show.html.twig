{% extends 'base.html.twig' %}

{% block title %}{{ category.name }} - Comeat{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .detail-container {
            max-width: 900px;
            margin: 0 auto;
        }

        .detail-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
        }

        .detail-actions {
            display: flex;
            gap: 1rem;
        }

        .detail-card {
            background: var(--bg-card);
            border-radius: 14px;
            padding: 0;
            border: 1px solid var(--border);
            box-shadow: 0 2px 8px rgba(62, 44, 35, 0.05);
            margin-bottom: 2rem;
            overflow: hidden;
        }

        .detail-row {
            display: grid;
            grid-template-columns: 200px 1fr;
            padding: 1rem 1.5rem;
            border-bottom: 1px solid var(--border);
        }

        .detail-row:last-child {
            border-bottom: none;
        }

        .detail-label {
            font-weight: 600;
            color: var(--text-primary);
            font-size: 0.9rem;
        }

        .detail-value {
            color: var(--text-secondary);
            font-size: 0.9rem;
        }

        .badge-id {
            display: inline-block;
            padding: 0.25rem 0.65rem;
            border-radius: 100px;
            font-size: 0.8rem;
            font-weight: 600;
            background-color: var(--bg-elevated);
            color: var(--text-muted);
        }

        .code-slug {
            background: var(--bg-elevated);
            color: var(--text-secondary);
            padding: 0.2rem 0.5rem;
            border-radius: 6px;
            font-family: monospace;
            font-size: 0.85rem;
        }
    </style>
{% endblock %}

{% block body %}
    <div class="detail-container">
        <div style="margin-bottom: 1.5rem;">
            <a href="{{ path('app_category_index') }}" style="color: var(--primary); text-decoration: none; font-size: 0.9rem; font-weight: 500;">&larr; Retour à la liste</a>
        </div>

        <div class="detail-header">
            <h1 style="font-size: 2rem; font-weight: 700; color: var(--text-primary);">{{ category.name }}</h1>
            <div class="detail-actions">
                <a href="{{ path('app_category_edit', {'id': category.id}) }}" class="btn btn-primary" style="width: auto;">Éditer</a>
            </div>
        </div>

        <div class="detail-card">
            <div class="detail-row">
                <div class="detail-label">ID</div>
                <div class="detail-value"><span class="badge-id">#{{ category.id }}</span></div>
            </div>

            <div class="detail-row">
                <div class="detail-label">Nom</div>
                <div class="detail-value">{{ category.name }}</div>
            </div>

            <div class="detail-row">
                <div class="detail-label">Description</div>
                <div class="detail-value">{{ category.description ?? '-' }}</div>
            </div>

            <div class="detail-row">
                <div class="detail-label">Slug</div>
                <div class="detail-value"><code class="code-slug">{{ category.slug }}</code></div>
            </div>

            <div class="detail-row">
                <div class="detail-label">Date de création</div>
                <div class="detail-value">{{ category.createdAt ? category.createdAt|date('d/m/Y à H:i') : '-' }}</div>
            </div>

            <div class="detail-row">
                <div class="detail-label">Dernière modification</div>
                <div class="detail-value">{{ category.updatedAt ? category.updatedAt|date('d/m/Y à H:i') : '-' }}</div>
            </div>
        </div>

        <div style="display: flex; gap: 1rem;">
            <a href="{{ path('app_category_edit', {'id': category.id}) }}" class="btn btn-primary" style="width: auto;">Éditer cette catégorie</a>
            {{ include('category/_delete_form.html.twig') }}
        </div>
    </div>
{% endblock %}
