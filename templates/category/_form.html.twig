{{ form_start(form) }}
    <div class="form-group">
        {{ form_label(form.name, 'Nom de la catégorie', {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.name, {'attr': {'class': 'form-control', 'placeholder': 'Ex: Électronique'}}) }}
        {{ form_errors(form.name) }}
    </div>

    <div class="form-group">
        {{ form_label(form.description, 'Description', {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 4, 'placeholder': 'Description de la catégorie...'}}) }}
        {{ form_errors(form.description) }}
        <small style="display: block; margin-top: 0.25rem; color: var(--text-muted); font-size: 0.875rem;">Optionnel</small>
    </div>

    <button type="submit" class="btn btn-primary">{{ button_label|default('Créer') }}</button>
{{ form_end(form) }}
