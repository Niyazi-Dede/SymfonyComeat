{% extends 'base.html.twig' %}

{% block title %}Éditer la catégorie - Comeat{% endblock %}

{% block body %}
    <div class="form-container" style="max-width: 700px;">
        <div style="margin-bottom: 1.5rem;">
            <a href="{{ path('app_category_index') }}" style="color: #0066c0; text-decoration: none;">&larr; Retour à la liste</a>
        </div>

        <h1 class="form-title">Éditer : {{ category.name }}</h1>

        {{ include('category/_form.html.twig', {'button_label': 'Mettre à jour'}) }}

        <div style="margin-top: 2rem; padding-top: 2rem; border-top: 1px solid #ddd;">
            {{ include('category/_delete_form.html.twig') }}
        </div>
    </div>
{% endblock %}
