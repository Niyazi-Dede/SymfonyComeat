<form method="post" action="{{ path('app_category_delete', {'id': category.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette catégorie ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ category.id) }}">
    <button type="submit" class="btn" style="background: var(--error); color: #fff; width: auto; box-shadow: 0 4px 14px rgba(239, 68, 68, 0.2);">Supprimer cette catégorie</button>
</form>
