{% extends 'base.html.twig' %}

{% block title %}Toutes les catégories - Comeat{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .page-header {
            margin-bottom: 2rem;
        }

        .page-title {
            font-size: 2rem;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: 0.5rem;
        }

        .page-subtitle {
            color: var(--text-secondary);
            font-size: 1.1rem;
        }

        .category-card {
            background: var(--bg-card);
            border-radius: 14px;
            padding: 2rem;
            text-align: center;
            border: 1px solid var(--border);
            box-shadow: 0 2px 8px rgba(62, 44, 35, 0.05);
            transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
            cursor: pointer;
            text-decoration: none;
            color: inherit;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 1rem;
        }

        .category-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 32px rgba(62, 44, 35, 0.12);
            border-color: var(--primary);
        }

        .category-icon {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, var(--primary) 0%, var(--olive) 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 2rem;
            font-weight: 700;
        }

        .category-name {
            font-size: 1.25rem;
            font-weight: 600;
            color: var(--text-primary);
        }

        .category-description {
            color: var(--text-secondary);
            font-size: 0.95rem;
            line-height: 1.5;
        }

        .empty-state {
            text-align: center;
            padding: 4rem 2rem;
            background: var(--bg-card);
            border-radius: 14px;
            border: 1px dashed var(--border);
        }

        .empty-state-icon {
            font-size: 4rem;
            margin-bottom: 1rem;
            opacity: 0.5;
        }

        .empty-state-title {
            font-size: 1.5rem;
            font-weight: 600;
            margin-bottom: 0.5rem;
            color: var(--text-primary);
        }

        .empty-state-text {
            color: var(--text-secondary);
            font-size: 1rem;
        }
    </style>
{% endblock %}

{% block body %}
    <div class="page-header">
        <h1 class="page-title">Toutes les catégories</h1>
        <p class="page-subtitle">Explorez notre large sélection de produits par catégorie</p>
    </div>

    {% if categories|length > 0 %}
        <div class="grid-4">
            {% for category in categories %}
                <a href="{{ path('app_category_show', {id: category.id}) }}" class="category-card">
                    <div class="category-icon">
                        {{ category.name|slice(0, 1)|upper }}
                    </div>
                    <div>
                        <h3 class="category-name">{{ category.name }}</h3>
                        {% if category.description %}
                            <p class="category-description">{{ category.description|slice(0, 100) }}{% if category.description|length > 100 %}...{% endif %}</p>
                        {% endif %}
                    </div>
                </a>
            {% endfor %}
        </div>
    {% else %}
        <div class="empty-state">
            <div class="empty-state-icon">📦</div>
            <h2 class="empty-state-title">Aucune catégorie disponible</h2>
            <p class="empty-state-text">Les catégories seront bientôt disponibles</p>
        </div>
    {% endif %}
{% endblock %}
