{% extends 'base.html.twig' %}

{% block title %}{{ category.name }} - Comeat{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .breadcrumb {
            display: flex;
            gap: 0.5rem;
            align-items: center;
            margin-bottom: 2rem;
            font-size: 0.95rem;
            color: #666;
        }

        .breadcrumb a {
            color: #0066c0;
            text-decoration: none;
        }

        .breadcrumb a:hover {
            text-decoration: underline;
        }

        .category-header {
            background: white;
            padding: 2rem;
            border-radius: 8px;
            margin-bottom: 2rem;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }

        .category-title {
            font-size: 2rem;
            font-weight: 700;
            color: #1a1a1a;
            margin-bottom: 0.5rem;
        }

        .category-description {
            color: #666;
            font-size: 1rem;
            line-height: 1.6;
        }

        .products-count {
            margin-bottom: 1.5rem;
            color: #666;
            font-size: 1rem;
        }

        .product-card {
            background: white;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            transition: transform 0.2s, box-shadow 0.2s;
            cursor: pointer;
            display: flex;
            flex-direction: column;
            height: 100%;
        }

        .product-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 4px 16px rgba(0,0,0,0.15);
        }

        .product-image {
            width: 100%;
            height: 250px;
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
            font-weight: 700;
            color: #999;
        }

        .product-info {
            padding: 1.25rem;
            display: flex;
            flex-direction: column;
            flex: 1;
        }

        .product-name {
            font-size: 1.1rem;
            font-weight: 600;
            margin-bottom: 0.5rem;
            color: #1a1a1a;
        }

        .product-description {
            color: #666;
            font-size: 0.9rem;
            line-height: 1.5;
            margin-bottom: 1rem;
            flex: 1;
        }

        .product-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-top: 1rem;
            border-top: 1px solid #eee;
        }

        .product-price {
            font-size: 1.5rem;
            font-weight: 700;
            color: #b12704;
        }

        .product-stock {
            font-size: 0.875rem;
            color: #007600;
            font-weight: 500;
        }

        .product-stock.out-of-stock {
            color: #d13212;
        }

        .empty-products {
            text-align: center;
            padding: 4rem 2rem;
            background: white;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }

        .empty-products-icon {
            font-size: 4rem;
            margin-bottom: 1rem;
            opacity: 0.5;
        }

        .empty-products-title {
            font-size: 1.5rem;
            font-weight: 600;
            margin-bottom: 0.5rem;
            color: #1a1a1a;
        }

        .empty-products-text {
            color: #666;
            font-size: 1rem;
        }
    </style>
{% endblock %}

{% block body %}
    <div class="breadcrumb">
        <a href="{{ path('app_home') }}">Accueil</a>
        <span>/</span>
        <a href="{{ path('app_categories') }}">Catégories</a>
        <span>/</span>
        <span>{{ category.name }}</span>
    </div>

    <div class="category-header">
        <h1 class="category-title">{{ category.name }}</h1>
        {% if category.description %}
            <p class="category-description">{{ category.description }}</p>
        {% endif %}
    </div>

    {% if products|length > 0 %}
        <div class="products-count">
            {{ products|length }} produit{{ products|length > 1 ? 's' : '' }} dans cette catégorie
        </div>

        <div class="grid-4">
            {% for product in products %}
                <div class="product-card">
                    <div class="product-image">
                        {{ product.name|slice(0, 1)|upper }}
                    </div>
                    <div class="product-info">
                        <h3 class="product-name">{{ product.name }}</h3>
                        {% if product.description %}
                            <p class="product-description">
                                {{ product.description|slice(0, 120) }}{% if product.description|length > 120 %}...{% endif %}
                            </p>
                        {% endif %}
                        <div class="product-footer">
                            <div class="product-price">{{ product.price }} €</div>
                            <div class="product-stock {{ product.stock > 0 ? '' : 'out-of-stock' }}">
                                {% if product.stock > 0 %}
                                    En stock ({{ product.stock }})
                                {% else %}
                                    Rupture de stock
                                {% endif %}
                            </div>
                        </div>
                        <a href="{{ path('app_product_show', {id: product.id}) }}" class="btn btn-primary" style="margin-top: 1rem; width: 100%; font-size: 0.875rem; padding: 0.6rem 1rem; text-align: center;">
                            Voir le produit
                        </a>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="empty-products">
            <div class="empty-products-icon">📦</div>
            <h2 class="empty-products-title">Aucun produit disponible</h2>
            <p class="empty-products-text">Cette catégorie ne contient pas encore de produits</p>
            <div style="margin-top: 1.5rem;">
                <a href="{{ path('app_categories') }}" class="btn btn-primary" style="width: auto;">Voir toutes les catégories</a>
            </div>
        </div>
    {% endif %}
{% endblock %}
