{% extends 'base.html.twig' %}

{% block title %}{{ category.name }} - Comeat{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .breadcrumb {
            display: flex;
            gap: 0.5rem;
            align-items: center;
            margin-bottom: 2rem;
            font-size: 0.95rem;
            color: var(--text-muted);
        }

        .breadcrumb a {
            color: var(--primary);
            text-decoration: none;
        }

        .breadcrumb a:hover {
            text-decoration: underline;
        }

        .category-header {
            background: var(--bg-card);
            padding: 2rem;
            border-radius: 14px;
            margin-bottom: 2rem;
            border: 1px solid var(--border);
            box-shadow: none;
        }

        .category-title {
            font-size: 2rem;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: 0.5rem;
        }

        .category-description {
            color: var(--text-secondary);
            font-size: 1rem;
            line-height: 1.6;
        }

        .products-count {
            margin-bottom: 1.5rem;
            color: var(--text-secondary);
            font-size: 1rem;
        }

        .product-card {
            background: var(--bg-card);
            border-radius: 14px;
            overflow: hidden;
            border: 1px solid var(--border);
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
            transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
            cursor: pointer;
            display: flex;
            flex-direction: column;
            height: 100%;
        }

        .product-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 32px rgba(170, 255, 0, 0.06);
            border-color: var(--primary);
        }

        .product-image {
            width: 100%;
            height: 250px;
            background: linear-gradient(135deg, var(--bg-elevated) 0%, var(--bg-section) 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
            font-weight: 700;
            color: var(--text-muted);
        }

        .product-info {
            padding: 1.25rem;
            display: flex;
            flex-direction: column;
            flex: 1;
        }

        .product-name {
            font-size: 1.1rem;
            font-weight: 600;
            margin-bottom: 0.5rem;
            color: var(--text-primary);
        }

        .product-description {
            color: var(--text-secondary);
            font-size: 0.9rem;
            line-height: 1.5;
            margin-bottom: 1rem;
            flex: 1;
        }

        .product-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-top: 1rem;
            border-top: 1px solid var(--border);
        }

        .product-price {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--primary);
        }

        .product-stock {
            font-size: 0.875rem;
            color: var(--olive);
            font-weight: 500;
        }

        .product-stock.out-of-stock {
            color: var(--primary);
        }

        .empty-products {
            text-align: center;
            padding: 4rem 2rem;
            background: var(--bg-card);
            border-radius: 14px;
            border: 1px dashed var(--border);
        }

        .empty-products-icon {
            font-size: 4rem;
            margin-bottom: 1rem;
            opacity: 0.5;
        }

        .empty-products-title {
            font-size: 1.5rem;
            font-weight: 600;
            margin-bottom: 0.5rem;
            color: var(--text-primary);
        }

        .empty-products-text {
            color: var(--text-secondary);
            font-size: 1rem;
        }
    </style>
{% endblock %}

{% block body %}
    <div class="breadcrumb">
        <a href="{{ path('app_home') }}">Accueil</a>
        <span>/</span>
        <a href="{{ path('app_categories') }}">Catégories</a>
        <span>/</span>
        <span>{{ category.name }}</span>
    </div>

    <div class="category-header">
        <h1 class="category-title">{{ category.name }}</h1>
        {% if category.description %}
            <p class="category-description">{{ category.description }}</p>
        {% endif %}
    </div>

    {% if products|length > 0 %}
        <div class="products-count">
            {{ products|length }} produit{{ products|length > 1 ? 's' : '' }} dans cette catégorie
        </div>

        <div class="grid-4 fade-up">
            {% for product in products %}
                <div class="product-card">
                    <div class="product-image">
                        {{ product.name|slice(0, 1)|upper }}
                    </div>
                    <div class="product-info">
                        <h3 class="product-name">{{ product.name }}</h3>
                        {% if product.description %}
                            <p class="product-description">
                                {{ product.description|slice(0, 120) }}{% if product.description|length > 120 %}...{% endif %}
                            </p>
                        {% endif %}
                        <div class="product-footer">
                            <div class="product-price">{{ product.price }} €</div>
                            <div class="product-stock {{ product.stock > 0 ? '' : 'out-of-stock' }}">
                                {% if product.stock > 0 %}
                                    En stock ({{ product.stock }})
                                {% else %}
                                    Rupture de stock
                                {% endif %}
                            </div>
                        </div>
                        <div style="display: flex; gap: 0.5rem; margin-top: 1rem;">
                            <form action="{{ path('app_cart_add', {id: product.id}) }}" method="POST" data-cart-form style="flex: 1;">
                                <input type="hidden" name="_token" value="{{ csrf_token('cart_add_' ~ product.id) }}">
                                <input type="hidden" name="quantity" value="1">
                                <button type="submit" class="btn btn-primary" style="width: 100%; padding: 0.6rem 0.75rem; font-size: 0.8rem;">
                                    + Panier
                                </button>
                            </form>
                            <a href="{{ path('app_product_show', {id: product.id}) }}" class="btn btn-secondary" style="padding: 0.6rem 0.75rem; font-size: 0.8rem; white-space: nowrap;">
                                Voir
                            </a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="empty-products">
            <div class="empty-products-icon">📦</div>
            <h2 class="empty-products-title">Aucun produit disponible</h2>
            <p class="empty-products-text">Cette catégorie ne contient pas encore de produits</p>
            <div style="margin-top: 1.5rem;">
                <a href="{{ path('app_categories') }}" class="btn btn-primary" style="width: auto;">Voir toutes les catégories</a>
            </div>
        </div>
    {% endif %}
{% endblock %}
