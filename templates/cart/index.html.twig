{% extends 'base.html.twig' %}

{% block title %}Mon Panier - Comeat{% endblock %}

{% block body %}
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 2rem;">
        <h1 style="font-size: 1.75rem; font-weight: 800; color: var(--text-primary); letter-spacing: -0.02em;">
            Mon panier
            {% if cart|length > 0 %}
                <span style="font-size: 1rem; font-weight: 600; color: var(--text-muted); margin-left: 0.5rem;">
                    ({{ cart|length }} article{{ cart|length > 1 ? 's' : '' }})
                </span>
            {% endif %}
        </h1>
        <a href="{{ path('app_home') }}" style="color: var(--primary); font-size: 0.875rem; font-weight: 600; text-decoration: none;">
            &larr; Continuer mes achats
        </a>
    </div>

    {% if cart|length > 0 %}
        <div style="display: grid; grid-template-columns: 1fr 340px; gap: 2rem; align-items: start;">

            {# Tableau des articles #}
            <div style="background: var(--bg-card); border-radius: 14px; border: 1px solid var(--border); overflow: hidden;">
                <table style="width: 100%; border-collapse: collapse;">
                    <thead>
                        <tr style="background: var(--bg-elevated); border-bottom: 1px solid var(--border);">
                            <th style="padding: 1rem 1.5rem; text-align: left; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted);">Produit</th>
                            <th style="padding: 1rem; text-align: center; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted);">Prix</th>
                            <th style="padding: 1rem; text-align: center; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted);">Quantité</th>
                            <th style="padding: 1rem; text-align: right; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted);">Sous-total</th>
                            <th style="padding: 1rem 1.5rem; text-align: center; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted);"></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in cart %}
                            <tr style="border-bottom: 1px solid var(--border);">
                                {# Produit #}
                                <td style="padding: 1.25rem 1.5rem;">
                                    <div style="display: flex; align-items: center; gap: 1rem;">
                                        <div style="
                                            width: 52px; height: 52px; flex-shrink: 0;
                                            background: var(--bg-elevated);
                                            border-radius: 10px;
                                            display: flex; align-items: center; justify-content: center;
                                            font-size: 1.35rem; font-weight: 800; color: var(--text-secondary);
                                        ">{{ item.product.name|slice(0,1)|upper }}</div>
                                        <div>
                                            <a href="{{ path('app_product_show', {id: item.product.id}) }}" style="font-weight: 600; color: var(--text-primary); text-decoration: none; font-size: 0.95rem;">
                                                {{ item.product.name }}
                                            </a>
                                            {% if item.product.categories|length > 0 %}
                                                <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.2rem;">
                                                    {{ item.product.categories.first.name }}
                                                </div>
                                            {% endif %}
                                        </div>
                                    </div>
                                </td>

                                {# Prix unitaire #}
                                <td style="padding: 1.25rem 1rem; text-align: center; color: var(--text-secondary); font-size: 0.9rem;">
                                    {{ item.product.price }} €
                                </td>

                                {# Quantité modifiable #}
                                <td style="padding: 1.25rem 1rem; text-align: center;">
                                    <form action="{{ path('app_cart_update', {id: item.product.id}) }}" method="POST" style="display: flex; align-items: center; justify-content: center; gap: 0.5rem;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('cart_update_' ~ item.product.id) }}">
                                        <input type="number" name="quantity" value="{{ item.quantity }}"
                                               min="1" max="{{ item.product.stock }}"
                                               data-price="{{ item.product.price }}"
                                               data-product-id="{{ item.product.id }}"
                                               class="cart-qty-input"
                                               style="width: 64px; padding: 0.4rem 0.5rem; border: 1.5px solid var(--border); border-radius: 8px; text-align: center; font-size: 0.9rem; color: var(--text-primary); background: var(--bg-elevated);">
                                    </form>
                                </td>

                                {# Sous-total #}
                                <td id="subtotal-{{ item.product.id }}" style="padding: 1.25rem 1rem; text-align: right; font-weight: 700; color: var(--primary); font-size: 0.95rem;">
                                    {{ item.subtotal|number_format(2, ',', ' ') }} €
                                </td>

                                {# Supprimer #}
                                <td style="padding: 1.25rem 1.5rem; text-align: center;">
                                    <form action="{{ path('app_cart_remove', {id: item.product.id}) }}" method="POST">
                                        <input type="hidden" name="_token" value="{{ csrf_token('cart_remove_' ~ item.product.id) }}">
                                        <button type="submit" style="background: none; border: none; cursor: pointer; color: var(--text-muted); font-size: 1.1rem; padding: 0.25rem; border-radius: 6px; transition: color 0.2s;"
                                                title="Supprimer" onmouseover="this.style.color='#ef4444'" onmouseout="this.style.color='var(--text-muted)'">✕</button>
                                    </form>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>

                <div style="padding: 1rem 1.5rem; display: flex; justify-content: flex-start;">
                    <form action="{{ path('app_cart_clear') }}" method="POST"
                          onsubmit="return confirm('Vider tout le panier ?')">
                        <input type="hidden" name="_token" value="{{ csrf_token('cart_clear') }}">
                        <button type="submit" style="background: none; border: 1.5px solid var(--border); color: var(--text-muted); padding: 0.5rem 1rem; border-radius: 8px; cursor: pointer; font-size: 0.8rem; font-weight: 600; transition: all 0.2s;"
                                onmouseover="this.style.borderColor='#ef4444';this.style.color='#ef4444'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text-muted)'">
                            Vider le panier
                        </button>
                    </form>
                </div>
            </div>

            {# Récapitulatif commande #}
            <div style="background: var(--bg-card); border-radius: 14px; border: 1px solid var(--border); overflow: hidden; position: sticky; top: 90px;">
                <div style="padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--border); background: var(--bg-elevated);">
                    <h2 style="font-size: 1rem; font-weight: 700; color: var(--text-primary); text-transform: uppercase; letter-spacing: 0.06em;">Récapitulatif</h2>
                </div>
                <div style="padding: 1.5rem;">
                    {% for item in cart %}
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem; font-size: 0.875rem;">
                            <span id="sidebar-label-{{ item.product.id }}" style="color: var(--text-secondary);">{{ item.product.name }} × {{ item.quantity }}</span>
                            <span id="sidebar-subtotal-{{ item.product.id }}" style="font-weight: 600; color: var(--text-primary);">{{ item.subtotal|number_format(2, ',', ' ') }} €</span>
                        </div>
                    {% endfor %}

                    <div style="border-top: 2px solid var(--border); margin: 1rem 0; padding-top: 1rem; display: flex; justify-content: space-between; align-items: center;">
                        <span style="font-size: 1rem; font-weight: 700; color: var(--text-primary);">Total</span>
                        <span id="cart-grand-total" style="font-size: 1.5rem; font-weight: 800; color: var(--primary);">{{ total|number_format(2, ',', ' ') }} €</span>
                    </div>

                    <a href="{{ path('app_checkout') }}" class="btn btn-primary" style="width: 100%; text-align: center; margin-top: 0.5rem; font-size: 0.95rem;">
                        Passer la commande
                    </a>
                    <p style="text-align: center; font-size: 0.75rem; color: var(--text-muted); margin-top: 0.75rem;">
                        Paiement sécurisé par Stripe
                    </p>
                </div>
            </div>
        </div>

    {% else %}
        <div style="text-align: center; padding: 5rem 2rem; background: var(--bg-card); border-radius: 14px; border: 1px dashed var(--border);">
            <div style="font-size: 3rem; margin-bottom: 1rem;">🛒</div>
            <h2 style="font-size: 1.25rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.5rem;">Votre panier est vide</h2>
            <p style="color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 2rem;">Découvrez nos produits et ajoutez-en au panier.</p>
            <a href="{{ path('app_home') }}" class="btn btn-primary" style="width: auto;">Voir les produits</a>
        </div>
    {% endif %}

    <script>
        function formatPrice(value) {
            return value.toFixed(2).replace('.', ',') + '\u00a0€';
        }

        function recalcTotal() {
            var total = 0;
            document.querySelectorAll('.cart-qty-input').forEach(function (input) {
                var qty = Math.max(1, parseInt(input.value) || 1);
                var price = parseFloat(input.dataset.price);
                total += qty * price;
            });
            var el = document.getElementById('cart-grand-total');
            if (el) el.textContent = formatPrice(total);
        }

        document.querySelectorAll('.cart-qty-input').forEach(function (input) {
            input.addEventListener('change', function () {
                var qty = Math.max(1, parseInt(this.value) || 1);
                this.value = qty;
                var form = this.closest('form');
                var data = new FormData(form);
                fetch(form.action, {
                    method: 'POST',
                    body: data,
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });
            });
            input.addEventListener('input', function () {
                var qty = Math.max(0, parseInt(this.value) || 0);
                var price = parseFloat(this.dataset.price);
                var id = this.dataset.productId;
                var subtotal = qty * price;

                var subtotalCell = document.getElementById('subtotal-' + id);
                if (subtotalCell) subtotalCell.textContent = formatPrice(subtotal);

                var sidebarLabel = document.getElementById('sidebar-label-' + id);
                if (sidebarLabel) {
                    var name = sidebarLabel.textContent.split('\u00d7')[0].trim();
                    sidebarLabel.textContent = name + ' \u00d7 ' + qty;
                }
                var sidebarSubtotal = document.getElementById('sidebar-subtotal-' + id);
                if (sidebarSubtotal) sidebarSubtotal.textContent = formatPrice(subtotal);

                recalcTotal();
            });
        });
    </script>
{% endblock %}
