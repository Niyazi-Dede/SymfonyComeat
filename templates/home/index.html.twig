{% extends 'base.html.twig' %}

{% block title %}Comeat - Accueil{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    /* ── Cartes catégories ── */
    .cat-card {
        display: block;
        text-decoration: none;
        border-radius: 18px;
        padding: 1.75rem 1.5rem;
        min-height: 190px;
        position: relative;
        overflow: hidden;
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

    .cat-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 22px 52px rgba(62, 44, 35, 0.22);
    }

    /* Grosse lettre décorative en arrière-plan */
    .cat-card-letter {
        position: absolute;
        right: -0.5rem;
        bottom: -2.25rem;
        font-size: 9rem;
        font-weight: 800;
        opacity: 0.12;
        line-height: 1;
        pointer-events: none;
        letter-spacing: -0.05em;
        user-select: none;
    }

    .cat-card-body {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        height: 100%;
        min-height: 150px;
    }

    .cat-card-icon {
        width: 44px;
        height: 44px;
        background: rgba(255, 255, 255, 0.18);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        font-weight: 800;
    }

    .cat-card-name {
        font-size: 1.15rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        margin-bottom: 0.3rem;
    }

    .cat-card-desc {
        font-size: 0.78rem;
        opacity: 0.68;
        line-height: 1.45;
        margin: 0;
    }

    /* ── Thèmes couleurs (palette artisanale) ── */
    .cat-t1 { background: #3E2C23; color: #FAF9F6; }
    .cat-t1 .cat-card-letter { color: #D7C2A3; }
    .cat-t1 .cat-card-icon { background: rgba(215, 194, 163, 0.2); color: #D7C2A3; }

    .cat-t2 { background: #C0392B; color: #FAF9F6; }
    .cat-t2 .cat-card-letter { color: #FAF9F6; }
    .cat-t2 .cat-card-icon { background: rgba(255, 255, 255, 0.18); color: #fff; }

    .cat-t3 { background: #D7C2A3; color: #3E2C23; }
    .cat-t3 .cat-card-letter { color: #3E2C23; }
    .cat-t3 .cat-card-icon { background: rgba(62, 44, 35, 0.12); color: #3E2C23; }

    .cat-t4 { background: #556B2F; color: #FAF9F6; }
    .cat-t4 .cat-card-letter { color: #EEF2E6; }
    .cat-t4 .cat-card-icon { background: rgba(255, 255, 255, 0.18); color: #fff; }
</style>
{% endblock %}

{% block hero %}
<section style="
    background: linear-gradient(135deg, #2C1810 0%, #3E2C23 60%, #5C3D2E 100%);
    padding: 5rem 2rem;
    position: relative;
    overflow: hidden;
">
    <!-- Decorative circles -->
    <div style="
        position: absolute; top: -60px; right: -60px;
        width: 320px; height: 320px;
        border-radius: 50%;
        background: rgba(215, 194, 163, 0.10);
        pointer-events: none;
    "></div>
    <div style="
        position: absolute; bottom: -80px; left: 10%;
        width: 200px; height: 200px;
        border-radius: 50%;
        background: rgba(215, 194, 163, 0.07);
        pointer-events: none;
    "></div>

    <div style="max-width: 1400px; margin: 0 auto; position: relative; z-index: 1;">
        <div style="max-width: 640px;">
            <span style="
                display: inline-block;
                background: rgba(85, 107, 47, 0.25);
                color: #A8C36A;
                font-size: 0.78rem;
                font-weight: 700;
                letter-spacing: 0.1em;
                text-transform: uppercase;
                padding: 0.35rem 0.9rem;
                border-radius: 100px;
                margin-bottom: 1.25rem;
                border: 1px solid rgba(85, 107, 47, 0.4);
            ">Marketplace alimentaire</span>

            <h1 style="
                font-size: clamp(2rem, 5vw, 3.25rem);
                font-weight: 800;
                color: #ffffff;
                line-height: 1.15;
                margin-bottom: 1.25rem;
                letter-spacing: -0.03em;
            ">
                Découvrez les<br>
                meilleures <span style="color: #D7C2A3;">saveurs</span>
            </h1>

            <p style="
                font-size: 1.05rem;
                color: rgba(255,255,255,0.7);
                margin-bottom: 2rem;
                max-width: 480px;
                line-height: 1.7;
            ">
                Des produits soigneusement sélectionnés, livrés directement chez vous. Qualité, fraîcheur et simplicité.
            </p>

            <a href="{{ path('app_categories') }}" class="btn btn-primary" style="padding: 0.875rem 2.25rem; font-size: 1rem; width: auto;">
                Explorer les catégories
            </a>
        </div>
    </div>
</section>
{% endblock %}

{% block body %}
    {% if categories|length > 0 %}
        <div style="margin-bottom: 3.5rem;">
            <div class="section-header">
                <h2>Catégories</h2>
                <div class="section-line"></div>
                <a href="{{ path('app_categories') }}" style="font-size: 0.85rem; font-weight: 600; color: var(--primary); text-decoration: none; white-space: nowrap;">Voir tout &rarr;</a>
            </div>

            {% set themes = ['cat-t1', 'cat-t2', 'cat-t3', 'cat-t4'] %}
            <div class="grid-4">
                {% for category in categories|slice(0, 4) %}
                    <a href="{{ path('app_category_show', {id: category.id}) }}"
                       class="cat-card {{ themes[loop.index0 % 4] }}">

                        {# Lettre décorative #}
                        <div class="cat-card-letter">{{ category.name|slice(0, 1)|upper }}</div>

                        <div class="cat-card-body">
                            <div class="cat-card-icon">{{ category.name|slice(0, 1)|upper }}</div>
                            <div>
                                <div class="cat-card-name">{{ category.name }}</div>
                                {% if category.description %}
                                    <p class="cat-card-desc">{{ category.description|slice(0, 50) }}{% if category.description|length > 50 %}…{% endif %}</p>
                                {% endif %}
                            </div>
                        </div>
                    </a>
                {% endfor %}
            </div>
        </div>
    {% endif %}

    <div>
        <div class="section-header">
            <h2>Derniers produits</h2>
            <div class="section-line"></div>
        </div>

        {% if products|length > 0 %}
            <div class="grid-4">
                {% for product in products %}
                    <div class="card">
                        <div class="card-img">
                            {{ product.name|slice(0, 1)|upper }}
                        </div>
                        <div class="card-body">
                            <h3 class="card-title">{{ product.name }}</h3>
                            <div class="price-badge">{{ product.price }} €</div>
                            {% if product.description %}
                                <p class="card-text">{{ product.description|slice(0, 75) }}{% if product.description|length > 75 %}…{% endif %}</p>
                            {% endif %}
                            <div style="display: flex; gap: 0.5rem; margin-top: 1rem;">
                                <form action="{{ path('app_cart_add', {id: product.id}) }}" method="POST" data-cart-form style="flex: 1;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('cart_add_' ~ product.id) }}">
                                    <input type="hidden" name="quantity" value="1">
                                    <button type="submit" class="btn btn-accent" style="width: 100%; font-size: 0.8rem; padding: 0.6rem 0.75rem;">
                                        + Panier
                                    </button>
                                </form>
                                <a href="{{ path('app_product_show', {id: product.id}) }}" class="btn btn-secondary" style="font-size: 0.8rem; padding: 0.6rem 0.75rem; white-space: nowrap;">
                                    Voir
                                </a>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div style="
                text-align: center;
                padding: 4rem 2rem;
                background: var(--bg-card);
                border-radius: 14px;
                border: 1px dashed var(--border);
            ">
                <div style="font-size: 2.5rem; margin-bottom: 1rem;">🛒</div>
                <p style="color: var(--text-secondary); font-size: 0.95rem;">Aucun produit disponible pour le moment.</p>
            </div>
        {% endif %}
    </div>
{% endblock %}
